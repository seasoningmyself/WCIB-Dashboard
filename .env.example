# Local application mode
NODE_ENV=development
PORT=5000

# Local Compose uses the db service name. Production replaces this entire value
# with the DigitalOcean managed Postgres connection string.
DATABASE_URL=postgresql://wcib:wcib_local_password@db:5432/wcib

# Optional: future deployments may supply a separate migration-role URL.
# Local development falls back to DATABASE_URL when this is unset.
# DATABASE_MIGRATE_URL=postgresql://wcib:wcib_local_password@db:5432/wcib

# Fake local-only value. Production must use a unique secret of at least 32
# characters and will reject this example-style value.
SESSION_SECRET=local-development-only-change-before-production

# Require administrator enrollment only, or require enrollment for every
# active account. Production policy may enable both flags.
WCIB_ADMIN_MFA_REQUIRED=false
WCIB_MFA_REQUIRED=false

# Production requires an independent 32-byte hexadecimal encryption key for
# TOTP secrets. Generate one with: openssl rand -hex 32
# MFA_ENCRYPTION_KEY_ID=2026-07-primary
# MFA_ENCRYPTION_KEY=<64-character-hex-key>
# MFA_PREVIOUS_ENCRYPTION_KEYS=older-key-id:<64-character-hex-key>

# Production requires the public HTTPS origin and matching relying-party host.
# WEBAUTHN_ORIGIN=https://dashboard.example.com
# WEBAUTHN_RP_ID=dashboard.example.com
# WEBAUTHN_RP_NAME=West Coast Insurance Brokers

# Optional support-dashboard release identity. Production images should set
# these as Docker build arguments from the verified commit and deploy time.
# WCIB_RELEASE_SHA=<40-character-commit-sha>
# WCIB_DEPLOYED_AT=2026-07-22T18:00:00.000Z

# Optional read-only Sentry support integration. Configure all three required
# values together. The token stays server-side and should have only the scopes
# needed to read organization issues and uptime results.
# SENTRY_API_TOKEN=<server-only-read-token>
# SENTRY_ORG_SLUG=wcib
# SENTRY_PROJECT_SLUG=dashboard
# SENTRY_ENVIRONMENT=production
# SENTRY_UPTIME_MONITOR_ID=<uptime-subscription-id>
# SENTRY_API_BASE_URL=https://sentry.io/api/0

# Optional read-only DigitalOcean backup integration. The token should have
# database:read only. PITR is an explicit deployment assertion because the
# backup-list API does not report that setting.
# DIGITALOCEAN_SUPPORT_API_TOKEN=<server-only-database-read-token>
# DIGITALOCEAN_DATABASE_CLUSTER_ID=<managed-database-uuid>
# DIGITALOCEAN_DATABASE_PITR_ENABLED=true
# DIGITALOCEAN_API_BASE_URL=https://api.digitalocean.com/v2
# WCIB_BACKUP_FRESHNESS_HOURS=30

# Seed-only and intentionally unset. Put the six keyed email/password objects
# in an ignored local .env only when running `npm run db:seed:roster`.
# WCIB_SEED_ROSTER_JSON={"kaylee":{...},"mercedes":{...},"daniela":{...},"joseph":{...},"ellyscia":{...},"sophia":{...}}

# Browser development only; Vite proxies /api to this target.
WCIB_API_PROXY_TARGET=http://127.0.0.1:5000
