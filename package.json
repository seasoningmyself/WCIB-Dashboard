{
  "name": "wcib-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node script/dev.mjs",
    "dev:server": "NODE_ENV=development node --import tsx server/index.ts",
    "dev:client": "vite",
    "build:client": "vite build",
    "check": "npm run check:backend && npm run check:frontend",
    "check:backend": "tsc --noEmit",
    "check:frontend": "tsc -p client/tsconfig.json --noEmit",
    "test": "node script/run-tests.mjs"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/express": "^5.0.0",
    "@types/node": "^20.19.27",
    "@vitejs/plugin-react": "^4.7.0",
    "tsx": "^4.20.5",
    "typescript": "^5.6.3",
    "vite": "^7.3.0"
  }
}
