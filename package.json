{
  "name": "wcib-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node script/dev.mjs",
    "dev:server": "NODE_ENV=development node --import tsx server/index.ts",
    "dev:client": "vite",
    "build:client": "vite build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --import tsx script/migrate.ts",
    "db:seed:roster": "node --import tsx script/seed-roster.ts",
    "db:check": "drizzle-kit check",
    "db:smoke": "node --import tsx script/db-smoke.ts",
    "check": "npm run check:backend && npm run check:frontend",
    "check:backend": "tsc --noEmit",
    "check:frontend": "tsc -p client/tsconfig.json --noEmit",
    "test": "node script/run-tests.mjs",
    "test:db:login": "node --import tsx --test server/http/auth.db-test.ts",
    "test:db:roster-seed": "node --import tsx --test server/auth/initial-roster.db-test.ts",
    "test:db:mfa-scaffold": "node --import tsx --test server/auth/mfa-scaffold.db-test.ts",
    "test:db:password-reset": "node --import tsx --test server/http/password-reset.db-test.ts",
    "test:db:session": "node --import tsx --test server/auth/sessions.db-test.ts",
    "test:db:user": "node --import tsx --test server/auth/users.db-test.ts",
    "test:db:staff": "node --import tsx --test server/auth/staff-accounts.db-test.ts",
    "test:db:access": "node --import tsx --test server/auth/access-model.db-test.ts",
    "test:db:producer-rate-history": "node --import tsx --test server/db/producer-rate-history.db-test.ts",
    "test:db:producer-rate-integrity": "node --import tsx --test server/db/producer-rate-integrity.db-test.ts",
    "test:db:office-locations": "node --import tsx --test server/db/office-locations.db-test.ts",
    "test:db:mgas": "node --import tsx --test server/db/mgas.db-test.ts",
    "test:db:carriers": "node --import tsx --test server/db/carriers.db-test.ts",
    "test:db:policy-types": "node --import tsx --test server/db/policy-types.db-test.ts",
    "test:db:vocabulary-integrity": "node --import tsx --test server/db/carriers.db-test.ts server/db/policy-types.db-test.ts",
    "test:db:drafts": "node --import tsx --test server/db/drafts.db-test.ts",
    "test:db:draft-integrity": "node --import tsx --test server/db/draft-integrity.db-test.ts",
    "test:db:approval-queue": "node --import tsx --test server/db/approval-queue.db-test.ts",
    "test:db:policies": "node --import tsx --test server/db/policies.db-test.ts",
    "test:db:policy-payment-stub": "node --import tsx --test server/db/policy-payment-stub.db-test.ts",
    "test:db:audit-events": "node --import tsx --test server/db/audit-events.db-test.ts",
    "test:db:audit-integrity": "node --import tsx --test server/db/audit-integrity.db-test.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.0.1",
    "express-session": "^1.19.0",
    "pg": "^8.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.2",
    "@types/node": "^20.19.27",
    "@types/pg": "^8.11.6",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.5",
    "typescript": "^5.6.3",
    "vite": "^7.3.0"
  },
  "overrides": {
    "drizzle-kit": {
      "@esbuild-kit/esm-loader": "npm:tsx@^4.20.4"
    }
  }
}
